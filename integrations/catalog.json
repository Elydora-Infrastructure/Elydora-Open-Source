    {
      "id": "augment",
      "name": "Augment Code CLI",
      "vendor": "Augment Code",
      "surface": "cli",
      "integration_mode": "command_hooks",
      "config_format": "json",
      "config_paths": [
        "/etc/augment/settings.json",
        "C:\\ProgramData\\Augment\\settings.json",
        ".augment/settings.local.json",
        ".augment/settings.json",
        "~/.augment/settings.json"
      ],
      "events": {
        "before_tool": "PreToolUse",
        "after_tool": "PostToolUse"
      },
      "event_fields": {
        "name": "tool_name",
        "input": "tool_input",
        "session": "conversation_id"
      },
      "blocking": {
        "mechanism": "exit_code_2",
        "failure_mode": "fail_open"
      },
      "adapters": { "node": true, "python": true, "go": true },
      "delivery_state": "available",
      "source_url": "https://docs.augmentcode.com/cli/hooks"
    },
